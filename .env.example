# Example environment variables for local development. Do NOT commit real secrets.
# Copy this to .env and replace placeholders with real values.

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=biursite
DB_USERNAME=<YOUR_DB_USERNAME>
DB_PASSWORD=<YOUR_DB_PASSWORD>

# JWT
JWT_SECRET=your-very-long-random-secret-at-least-32-chars
JWT_EXPIRATION_MS=3600000

# Optional runtime
SERVER_PORT=8080
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false
THYMELEAF_CACHE=true

# Test-specific variables (CI should set these via secrets)
JWT_SECRET_TEST=your-test-secret-min-32-chars
DB_USERNAME_TEST=sa
DB_PASSWORD_TEST=
