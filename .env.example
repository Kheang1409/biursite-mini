# Example .env (DO NOT commit real secrets)
# Copy to .env and populate values

# Database (use full JDBC URL; do not put real secrets in this file)
# Example:
# SPRING_DATASOURCE_URL=jdbc:postgresql://db-host.example.com:5432/biursite?sslmode=require
# SPRING_DATASOURCE_USERNAME=<YOUR_DB_USERNAME>
# SPRING_DATASOURCE_PASSWORD=<YOUR_DB_PASSWORD>

# JWT (use a strong secret, minimum 32 characters)
# JWT_SECRET=<YOUR_LONG_JWT_SECRET>
# JWT_EXPIRATION_MS=3600000

# Application
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false
THYMELEAF_CACHE=true
# Example environment variables for local development.
# Copy this file to .env and replace the <PLACEHOLDERS> below.
# Do NOT commit real secrets to version control.

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=biursite
DB_USERNAME=<YOUR_DB_USERNAME>
DB_PASSWORD=<YOUR_DB_PASSWORD>

# JWT (use a strong secret, minimum 32 characters)
JWT_SECRET=<YOUR_LONG_JWT_SECRET>
JWT_EXPIRATION_MS=3600000

# Spring profile to activate (application-prod.yml exists and uses profile 'prod')
SPRING_PROFILES_ACTIVE=prod

# Optional runtime
SERVER_PORT=8080
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false
THYMELEAF_CACHE=true